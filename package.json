{
  "name": "miniprogram-websocket",
  "version": "1.0.3",
  "license": "MIT",
  "author": "Xingzeng Bao",
  "homepage": "https://github.com/baoxingzeng/miniprogram-websocket",
  "description": "A WebSocket API polyfill for mini programs.",
  "type": "module",
  "main": "dist/miniprogram-websocket.cjs.js",
  "module": "dist/miniprogram-websocket.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "README.md",
    "dist",
    "!dist/types/**/*",
    "!dist/cjs/types/**/*",
    "!dist/esm/types/**/*"
  ],
  "exports": {
    ".": {
      "require": "./dist/cjs/index.js",
      "import": "./dist/esm/index.js",
      "types": "./dist/index.d.ts"
    },
    "./dev": {
      "require": "./dist/cjs/dev.js",
      "import": "./dist/esm/dev.js",
      "types": "./dist/dev.d.ts"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "rollup --config",
    "test": "echo \"Follow the instructions in tests/README.txt to run the tests.\" && exit 1"
  },
  "keywords": [
    "miniprogram",
    "websocket",
    "polyfill"
  ],
  "dependencies": {
    "fetch-xhr-shim": ">=1.0.0",
    "miniprogram-platform": ">=1.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@rollup/plugin-babel": "^7.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "rollup": "^4.61.0",
    "rollup-plugin-dts": "^6.4.1",
    "tslib": "^2.8.1",
    "uvu": "^0.5.6",
    "ws": "^8.21.0"
  }
}
